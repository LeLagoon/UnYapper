{
    "name" : "UnYapper",
    "description" : "Summarize huge texts into simple sentences",
    "version" : "1.0",
    "manifest_version" : 3,
    "permissions" : [
        "storage",
        "tabs",
        "contextMenus",
        "activeTab",
        "scripting"
    ],
    "host_permissions" : ["https://ai.hackclub.com/proxy/v1/chat/completions"],
    "background" : {
        "service_worker" : "background.js"
    },
    "action" : {
        "default_popup" : "main.html",
        "default_icon" : "default_icon.png"
    }
}